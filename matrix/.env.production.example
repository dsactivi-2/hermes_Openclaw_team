# Project identity
PROJECT_NAME=matrix
APP_BRAND="Example Space"
BASE_DOMAIN=example.com
MATRIX_DOMAIN=matrix.example.com
ELEMENT_DOMAIN=space.example.com
ELEMENT_ADMIN_DOMAIN=admin.matrix.example.com
KETESA_DOMAIN=synapse-admin.example.com
TRAEFIK_DOMAIN=traefik.example.com

# Public URLs and DNS target
MATRIX_BASE_URL=https://matrix.example.com
MATRIX_HOMESERVER_URL=https://matrix.example.com
ELEMENT_BASE_URL=https://space.example.com
KETESA_BASE_URL=https://synapse-admin.example.com
ACME_EMAIL=admin@example.com
SERVER_PUBLIC_IP=change-me
REGISTRY_PREFIX=ghcr.io/OWNER_OR_ORG/matrix

# Local values used only for server-side audits if running locally
LOCAL_HOST=127.0.0.1
LOCAL_ELEMENT_URL=http://127.0.0.1:8081
LOCAL_ADMIN_URL=http://127.0.0.1:8082
LOCAL_MAILPIT_URL=http://127.0.0.1:8025

# Database
POSTGRES_DB=synapse
POSTGRES_USER=synapse
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CP_MIN=5
POSTGRES_CP_MAX=10
DB_PASSWORD=change-me

# Synapse
MATRIX_ADMIN_USER=admin
MATRIX_ADMIN_PASSWORD=change-me
MATRIX_ADMIN_USER_ID=@admin:matrix.example.com
MATRIX_LEGACY_USER_ID=@legacy-admin:matrix.example.com
SYNAPSE_REPORT_STATS=false
SYNAPSE_LISTENER_RESOURCES=client
SYNAPSE_MSC4186_ENABLED=true
SYNAPSE_MAX_UPLOAD_SIZE=100M
SYNAPSE_LOCAL_MEDIA_LIFETIME=180d
SYNAPSE_REMOTE_MEDIA_LIFETIME=30d
SYNAPSE_ENABLE_REGISTRATION=false
REGISTRATION_SHARED_SECRET=change-me
TRUSTED_KEY_SERVER=matrix.org

# TURN
TURN_REALM=example.com
TURN_HOST=matrix.example.com
LOCAL_TURN_HOST=127.0.0.1
TURN_PORT=3478
TURN_USERNAME=matrix
TURN_PASSWORD=change-me
TURN_USER_LIFETIME=1h
TURN_ALLOW_GUESTS=false

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=change-me
SMTP_PASSWORD=change-me
SMTP_REQUIRE_TLS=true
SMTP_FROM_NAME="Example Matrix"
SMTP_FROM_EMAIL=matrix@example.com
SMTP_ENABLE_NOTIFS=true
SMTP_NOTIF_FOR_NEW_USERS=false
LOCAL_SMTP_HOST=mailpit
LOCAL_SMTP_PORT=1025
LOCAL_SMTP_REQUIRE_TLS=false

# Element
ELEMENT_DEFAULT_THEME=dark
ELEMENT_SHOW_LABS_SETTINGS=true

# Traefik
SYNAPSE_ADMIN_BASIC_AUTH_USERS=admin:REPLACE_WITH_HTPASSWD_HASH
TRAEFIK_DASHBOARD_BASIC_AUTH_USERS=admin:REPLACE_WITH_HTPASSWD_HASH
TRAEFIK_STS_SECONDS=31536000
TRAEFIK_PUBLIC_RATE_AVERAGE=100
TRAEFIK_PUBLIC_RATE_BURST=200
TRAEFIK_ADMIN_RATE_AVERAGE=20
TRAEFIK_ADMIN_RATE_BURST=40

# Mirrored production images
TRAEFIK_IMAGE=ghcr.io/OWNER_OR_ORG/matrix/traefik:v3.3
POSTGRES_IMAGE=ghcr.io/OWNER_OR_ORG/matrix/postgres:17-alpine
SYNAPSE_IMAGE=ghcr.io/OWNER_OR_ORG/matrix/synapse:v1.153.0
ELEMENT_IMAGE=ghcr.io/OWNER_OR_ORG/matrix/element-web:v1.12.18
ELEMENT_ADMIN_IMAGE=ghcr.io/OWNER_OR_ORG/matrix/element-admin:0.1.11
KETESA_IMAGE=ghcr.io/OWNER_OR_ORG/matrix/ketesa:v1.2.1-7-g646f925
HERMES_IMAGE=nousresearch/hermes-agent@sha256:b6e41c155d6bfce5ad83c5d0fec670086db8a43250e4511c9474134be5482d33
COTURN_IMAGE=ghcr.io/OWNER_OR_ORG/matrix/coturn:4.11.0-r0
MAILPIT_IMAGE=ghcr.io/OWNER_OR_ORG/matrix/mailpit:v1.21

# Optional Hermes Agent add-on
SENA_MATRIX_USER_ID=@sena:matrix.example.com
SENA_MATRIX_ACCESS_TOKEN=change-me
SENA_MATRIX_ALLOWED_USERS=@admin:matrix.example.com
ACTIVI_MATRIX_USER_ID=@ops-agent:matrix.example.com
ACTIVI_MATRIX_ACCESS_TOKEN=change-me
ACTIVI_MATRIX_ALLOWED_USERS=@admin:matrix.example.com
