# Copy to a deployment secret store or to agents/activi/.env locally.
# Do not commit real values.

HERMES_HOME=/opt/data
HERMES_AGENT_NAME=activi
MATRIX_HOMESERVER_URL=https://matrix.activi.io
ACTIVI_MATRIX_USER_ID=@activi-agent:matrix.activi.io
ACTIVI_MATRIX_ACCESS_TOKEN=REPLACE_WITH_ACTIVI_AGENT_MATRIX_ACCESS_TOKEN
ACTIVI_MATRIX_ALLOWED_USERS=@activi:matrix.activi.io

# Add one or more model/provider credentials for Hermes.
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_API_KEY
OPENROUTER_API_KEY=REPLACE_WITH_OPENROUTER_API_KEY

# Optional later integrations.
AGENTMAIL_API_KEY=REPLACE_WITH_AGENTMAIL_API_KEY
GITHUB_TOKEN=REPLACE_WITH_GITHUB_TOKEN
GHCR_TOKEN=REPLACE_WITH_GHCR_TOKEN
