# Copy to a deployment secret store or to agents/sena/.env locally.
# Do not commit real values.

HERMES_HOME=/opt/data
HERMES_AGENT_NAME=sena
MATRIX_HOMESERVER_URL=https://matrix.activi.io
SENA_MATRIX_USER_ID=@sena:matrix.activi.io
SENA_MATRIX_ACCESS_TOKEN=REPLACE_WITH_SENA_MATRIX_ACCESS_TOKEN
SENA_MATRIX_ALLOWED_USERS=@activi:matrix.activi.io

# Add one or more model/provider credentials for Hermes.
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_API_KEY
OPENROUTER_API_KEY=REPLACE_WITH_OPENROUTER_API_KEY

# Optional later integrations.
LIVEKIT_URL=REPLACE_WITH_LIVEKIT_URL
LIVEKIT_API_KEY=REPLACE_WITH_LIVEKIT_API_KEY
LIVEKIT_API_SECRET=REPLACE_WITH_LIVEKIT_API_SECRET
TELNYX_API_KEY=REPLACE_WITH_TELNYX_API_KEY
N8N_BASE_URL=REPLACE_WITH_N8N_BASE_URL
N8N_API_KEY=REPLACE_WITH_N8N_API_KEY
