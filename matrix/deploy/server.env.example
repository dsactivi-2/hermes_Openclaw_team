# Copy this file to .env on the production server and replace every CHANGE_ME value.
# Do not commit the real .env file.

# Project identity
PROJECT_NAME=matrix
APP_BRAND="Activi Space"
BASE_DOMAIN=activi.io
MATRIX_DOMAIN=matrix.activi.io
ELEMENT_DOMAIN=space.activi.io
ELEMENT_ADMIN_DOMAIN=admin.matrix.activi.io
KETESA_DOMAIN=synapse-admin.activi.io
TRAEFIK_DOMAIN=traefik.activi.io

# Public URLs and DNS target
MATRIX_BASE_URL=https://matrix.activi.io
MATRIX_HOMESERVER_URL=https://matrix.activi.io
ELEMENT_BASE_URL=https://space.activi.io
KETESA_BASE_URL=https://synapse-admin.activi.io
ACME_EMAIL=admin@activi.io
SERVER_PUBLIC_IP=CHANGE_ME_SERVER_PUBLIC_IP
REGISTRY_PREFIX=ghcr.io/dsactivi-2/matrix

# Local audit URLs used only if this file is reused for local checks
LOCAL_HOST=127.0.0.1
LOCAL_ELEMENT_URL=http://127.0.0.1:8081
LOCAL_ADMIN_URL=http://127.0.0.1:8082
LOCAL_MAILPIT_URL=http://127.0.0.1:8025

# Database
POSTGRES_DB=synapse
POSTGRES_USER=synapse
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CP_MIN=5
POSTGRES_CP_MAX=10
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# Synapse
MATRIX_ADMIN_USER=activi
MATRIX_ADMIN_PASSWORD=CHANGE_ME_MATRIX_ADMIN_PASSWORD
MATRIX_ADMIN_USER_ID=@activi:matrix.activi.io
MATRIX_LEGACY_USER_ID=@admin:matrix.activi.io
SYNAPSE_REPORT_STATS=false
SYNAPSE_LISTENER_RESOURCES=client
SYNAPSE_MSC4186_ENABLED=true
SYNAPSE_MAX_UPLOAD_SIZE=100M
SYNAPSE_LOCAL_MEDIA_LIFETIME=180d
SYNAPSE_REMOTE_MEDIA_LIFETIME=30d
SYNAPSE_ENABLE_REGISTRATION=false
REGISTRATION_SHARED_SECRET=CHANGE_ME_REGISTRATION_SHARED_SECRET
TRUSTED_KEY_SERVER=matrix.org

# TURN
TURN_REALM=activi.io
TURN_HOST=matrix.activi.io
LOCAL_TURN_HOST=127.0.0.1
TURN_PORT=3478
TURN_USERNAME=matrix
TURN_PASSWORD=CHANGE_ME_TURN_PASSWORD
TURN_USER_LIFETIME=1h
TURN_ALLOW_GUESTS=false

# SMTP
SMTP_HOST=CHANGE_ME_SMTP_HOST
SMTP_PORT=587
SMTP_USER=CHANGE_ME_SMTP_USER
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_REQUIRE_TLS=true
SMTP_FROM_NAME="Activi Matrix"
SMTP_FROM_EMAIL=matrix@activi.io
SMTP_ENABLE_NOTIFS=true
SMTP_NOTIF_FOR_NEW_USERS=false
LOCAL_SMTP_HOST=mailpit
LOCAL_SMTP_PORT=1025
LOCAL_SMTP_REQUIRE_TLS=false

# Element
ELEMENT_DEFAULT_THEME=dark
ELEMENT_SHOW_LABS_SETTINGS=true

# Traefik
# Use htpasswd bcrypt hashes. Escape $ as $$ inside .env.
SYNAPSE_ADMIN_BASIC_AUTH_USERS=admin:CHANGE_ME_HTPASSWD_HASH
TRAEFIK_DASHBOARD_BASIC_AUTH_USERS=admin:CHANGE_ME_HTPASSWD_HASH
TRAEFIK_STS_SECONDS=31536000
TRAEFIK_PUBLIC_RATE_AVERAGE=100
TRAEFIK_PUBLIC_RATE_BURST=200
TRAEFIK_ADMIN_RATE_AVERAGE=20
TRAEFIK_ADMIN_RATE_BURST=40

# Mirrored production images
TRAEFIK_IMAGE=ghcr.io/dsactivi-2/matrix/traefik:v3.3
POSTGRES_IMAGE=ghcr.io/dsactivi-2/matrix/postgres:17-alpine
SYNAPSE_IMAGE=ghcr.io/dsactivi-2/matrix/synapse:v1.153.0
ELEMENT_IMAGE=ghcr.io/dsactivi-2/matrix/element-web:v1.12.18
ELEMENT_ADMIN_IMAGE=ghcr.io/dsactivi-2/matrix/element-admin:0.1.11
KETESA_IMAGE=ghcr.io/dsactivi-2/matrix/ketesa:v1.2.1-7-g646f925
HERMES_IMAGE=nousresearch/hermes-agent@sha256:b6e41c155d6bfce5ad83c5d0fec670086db8a43250e4511c9474134be5482d33
COTURN_IMAGE=ghcr.io/dsactivi-2/matrix/coturn:4.11.0-r0
MAILPIT_IMAGE=ghcr.io/dsactivi-2/matrix/mailpit:v1.21

# Optional Hermes Agent add-on. Leave disabled/empty until Matrix is stable.
SENA_MATRIX_USER_ID=@sena:matrix.activi.io
SENA_MATRIX_ACCESS_TOKEN=CHANGE_ME_LATER_OR_LEAVE_DISABLED
SENA_MATRIX_ALLOWED_USERS=@activi:matrix.activi.io
ACTIVI_MATRIX_USER_ID=@activi-agent:matrix.activi.io
ACTIVI_MATRIX_ACCESS_TOKEN=CHANGE_ME_LATER_OR_LEAVE_DISABLED
ACTIVI_MATRIX_ALLOWED_USERS=@activi:matrix.activi.io
